{
  "manifest_version": 3,
  "name": "Rewind: My YouTube Assistant",
  "version": "1.0.0",
  "description": "Your private YouTube companion. Search your watched history and chat with a helpful assistant that remembers what you saw.",
  "permissions": [
    "storage",
    "sidePanel",
    "alarms"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Open Privacy Vault",
    "default_icon": "icons/icon.svg"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "dashboard.html",
  "icons": {
    "16": "icons/icon.svg",
    "32": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
